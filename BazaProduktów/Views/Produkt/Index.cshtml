@model IEnumerable<BazaProduktow.Models.Produkt>

@{
    ViewData["Title"] = "Baza Produktów";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Baza Produktów</h2>
        <a asp-action="Dodaj" class="btn btn-success">+ Dodaj produkt</a>
    </div>

    @if (TempData["Sukces"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Sukces"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-5">
            <input type="text" name="szukaj" value="@ViewBag.Szukaj" class="form-control" placeholder="Szukaj po nazwie lub opisie..." />
        </div>
        <div class="col-md-4">
            <select name="kategoria" class="form-select">
                <option value="">-- Wszystkie kategorie --</option>
                @foreach (var kat in ViewBag.Kategorie)
                {
                    <option value="@kat" selected="@(ViewBag.Kategoria == kat)">@kat</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Szukaj</button>
        </div>
        <div class="col-md-1">
            <a asp-action="Index" class="btn btn-secondary w-100">X</a>
        </div>
    </form>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nazwa</th>
                <th>Kategoria</th>
                <th>Cena</th>
                <th>Data dodania</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Nazwa</td>
                    <td>@p.Kategoria</td>
                    <td>@p.Cena.ToString("C")</td>
                    <td>@p.DataDodania.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a asp-action="Edytuj" asp-route-id="@p.Id" class="btn btn-sm btn-primary">Edytuj</a>
                        <a asp-action="Usun" asp-route-id="@p.Id" class="btn btn-sm btn-danger">Usuń</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <p class="text-center text-muted mt-3">Brak produktów spełniających kryteria wyszukiwania.</p>
    }
</div>